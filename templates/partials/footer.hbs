<footer class="site-footer">
    <div class="footer-content">
        <div class="footer-section">
            <h3>About</h3>
            <p>{{description}}</p>
        </div>
        <div class="footer-section">
            <h3>Social</h3>
            <ul class="social-links">
                {{#if social.github}}
                <li><a href="https://github.com/{{social.github}}">GitHub</a></li>
                {{/if}}
                {{#if social.twitter}}
                <li><a href="https://twitter.com/{{social.twitter}}">Twitter</a></li>
                {{/if}}
                {{#if social.linkedin}}
                <li><a href="https://linkedin.com/in/{{social.linkedin}}">LinkedIn</a></li>
                {{/if}}
                {{#if social.email}}
                <li><a href="mailto:{{social.email}}">Email</a></li>
                {{/if}}
            </ul>
        </div>
        <div class="footer-section">
            <h3>Navigation</h3>
            <ul>
                {{#each navigation}}
                <li><a href="{{this.url}}">{{this.label}}</a></li>
                {{/each}}
            </ul>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; {{yearStarted}}-{{currentYear}} {{author}}. All rights reserved.</p>
        <p>Built with <a href="#">SSG Portfolio</a></p>
    </div>
</footer>
